{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"src/**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@components/*": [
				"src/components/*"
			],
			"@games/*": [
				"src/games/*"
			],
			"@layouts/*": [
				"src/layouts/*"
			],
			"@data/*": [
				"src/data/*"
			]
		}
	}
}